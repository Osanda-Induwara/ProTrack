# Backend Environment Variables Template

# ============================================
# MONGODB CONFIGURATION
# ============================================

# Option 1: Local MongoDB
MONGO_URI=mongodb://localhost:27017/project-manager

# Option 2: MongoDB Atlas (Cloud)
# MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/project-manager

# ============================================
# JWT CONFIGURATION
# ============================================

# Secret key for signing JWTs
# IMPORTANT: Change this to a random string in production!
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production_12345

# ============================================
# SERVER CONFIGURATION
# ============================================

# Port the server runs on
PORT=5000

# Environment: development or production
NODE_ENV=development

# Frontend URL (for CORS - allow requests from this origin)
CLIENT_URL=http://localhost:3000

# ============================================
# OPTIONAL: PRODUCTION SETTINGS
# ============================================

# Database backup
# DATABASE_BACKUP_URL=...

# Email service (for future notifications)
# SMTP_EMAIL=your-email@gmail.com
# SMTP_PASSWORD=app-specific-password

# AWS S3 (for file uploads)
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
# AWS_S3_BUCKET_NAME=...
